{
  "manifest_version": 3,
  "name": "RealHands",
  "version": "0.3.0",
  "description": "Browser executor for the realhands Autonomous Agent Runtime. Receives commands from a local Agent Bridge over WebSocket and executes generic browser primitives. Knows nothing about any specific site.",
  "permissions": [
    "storage",
    "tabs",
    "alarms",
    "windows",
    "debugger",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*/*",
    "http://localhost:7878/*",
    "http://127.0.0.1:7878/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "realhands"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
